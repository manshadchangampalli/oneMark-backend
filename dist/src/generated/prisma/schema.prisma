model UserSession {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @db.Uuid
  hashedRefreshToken String
  userAgent          String?
  ipAddress          String?
  lastUsedAt         DateTime  @default(now())
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([hashedRefreshToken])
}

generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DailyChallenge {
  id           String   @id @default(uuid()) @db.Uuid
  date         DateTime @db.Date // one challenge per (date, exam)
  examId       String   @db.Uuid
  questionId   String   @db.Uuid
  totalSolvers Int      @default(0) // denormalized; any completed attempt counts

  exam     Exam      @relation(fields: [examId], references: [id])
  question Question  @relation(fields: [questionId], references: [id])
  attempts Attempt[]

  createdAt DateTime @default(now())

  @@unique([date, examId])
  @@index([date])
}

model Exam {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique // 'jee', 'neet', 'ib', 'a-levels', 'psc', 'generic'
  label       String // 'JEE Advanced 2026'
  description String?
  isActive    Boolean @default(true)

  userExams       UserExam[]
  subjectExams    SubjectExam[]
  topicExams      TopicExam[]
  questionExams   QuestionExam[]
  sessions        PracticeSession[]
  dailyChallenges DailyChallenge[]

  createdAt DateTime @default(now())
}

model UserExam {
  userId     String   @db.Uuid
  examId     String   @db.Uuid
  isPrimary  Boolean  @default(false)
  enrolledAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  exam Exam @relation(fields: [examId], references: [id])

  @@id([userId, examId])
  @@index([userId])
  @@index([examId])
}

enum SessionMode {
  quick
  mock
  drill
  daily
  custom
}

enum SessionDifficulty {
  easy
  medium
  hard
  mixed
}

model PracticeSession {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @db.Uuid
  examId        String            @db.Uuid
  mode          SessionMode
  subjectId     String?           @db.Uuid
  topicId       String?           @db.Uuid
  difficulty    SessionDifficulty @default(mixed)
  questionCount Int
  timeLimitSec  Int?
  startedAt     DateTime          @default(now())
  finishedAt    DateTime?
  score         Int               @default(0)
  total         Int               @default(0)
  timeSpentSec  Int               @default(0)

  user             User              @relation(fields: [userId], references: [id])
  exam             Exam              @relation(fields: [examId], references: [id])
  sessionQuestions SessionQuestion[]
  attempts         Attempt[]

  @@index([userId, startedAt(sort: Desc)])
}

model SessionQuestion {
  sessionId  String @db.Uuid
  questionId String @db.Uuid
  sortOrder  Int

  session  PracticeSession @relation(fields: [sessionId], references: [id])
  question Question        @relation(fields: [questionId], references: [id])

  @@id([sessionId, sortOrder])
  @@unique([sessionId, questionId])
}

model Attempt {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  questionId         String   @db.Uuid
  questionRevisionId String   @db.Uuid
  sessionId          String?  @db.Uuid
  dailyChallengeId   String?  @db.Uuid
  selectedOptionId   String?  @db.Uuid
  isCorrect          Boolean
  timeSeconds        Int
  xpAwarded          Int
  attemptedAt        DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id])
  question         Question         @relation(fields: [questionId], references: [id])
  questionRevision QuestionRevision @relation(fields: [questionRevisionId], references: [id])
  session          PracticeSession? @relation(fields: [sessionId], references: [id])
  dailyChallenge   DailyChallenge?  @relation(fields: [dailyChallengeId], references: [id])
  selectedOption   QuestionOption?  @relation("SelectedOption", fields: [selectedOptionId], references: [id])

  @@index([userId, attemptedAt(sort: Desc)])
  @@index([userId, questionId])
  @@index([sessionId])
  @@index([dailyChallengeId])
  @@index([questionId, attemptedAt(sort: Desc)])
  @@index([questionRevisionId])
}

enum QuestionDifficulty {
  easy
  medium
  hard
}

enum QuestionType {
  mcq
}

enum QuestionStatus {
  draft
  published
  archived
}

model Question {
  id                  String             @id @default(uuid()) @db.Uuid
  subjectId           String             @db.Uuid
  topicId             String             @db.Uuid
  difficulty          QuestionDifficulty @default(medium)
  type                QuestionType       @default(mcq)
  status              QuestionStatus     @default(published)
  xpReward            Int                @default(50)
  successRate         Decimal?           @db.Decimal(5, 2)
  avgTimeSeconds      Int?
  discriminationIndex Decimal?           @db.Decimal(5, 2)
  currentRevisionId   String?            @unique @db.Uuid
  createdBy           String?            @db.Uuid

  subject          Subject            @relation(fields: [subjectId], references: [id])
  topic            Topic              @relation(fields: [topicId], references: [id])
  currentRevision  QuestionRevision?  @relation("CurrentRevision", fields: [currentRevisionId], references: [id])
  revisions        QuestionRevision[] @relation("Revisions")
  options          QuestionOption[]
  questionExams    QuestionExam[]
  sessionQuestions SessionQuestion[]
  attempts         Attempt[]
  dailyChallenges  DailyChallenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId, topicId])
  @@index([difficulty])
  @@index([status])
}

// Append-only — never edited after insert; links attempt history to exact question text
model QuestionRevision {
  id                  String             @id @default(uuid()) @db.Uuid
  questionId          String             @db.Uuid
  version             Int
  prompt              String
  correctOptionLabel  String // 'A' | 'B' | 'C' | 'D'
  officialExplanation Json? // { steps: string[] }
  difficulty          QuestionDifficulty
  xpReward            Int
  createdBy           String?            @db.Uuid
  createdAt           DateTime           @default(now())

  question   Question  @relation("Revisions", fields: [questionId], references: [id])
  currentFor Question? @relation("CurrentRevision")
  attempts   Attempt[]

  @@unique([questionId, version])
}

model QuestionOption {
  id         String  @id @default(uuid()) @db.Uuid
  questionId String  @db.Uuid
  label      String // 'A', 'B', 'C', 'D'
  text       String
  sub        String? // optional hint, e.g. "≈ 34.64 m"
  sortOrder  Int

  question Question  @relation(fields: [questionId], references: [id])
  attempts Attempt[] @relation("SelectedOption")

  @@unique([questionId, label])
}

model QuestionExam {
  questionId String @db.Uuid
  examId     String @db.Uuid

  question Question @relation(fields: [questionId], references: [id])
  exam     Exam     @relation(fields: [examId], references: [id])

  @@id([questionId, examId])
  @@index([examId])
}

model Subject {
  id        String @id @default(uuid()) @db.Uuid
  code      String @unique
  label     String
  short     String
  colorHex  String
  sortOrder Int    @default(0)

  subjectExams SubjectExam[]
  topics       Topic[]
  questions    Question[]

  createdAt DateTime @default(now())
}

model SubjectExam {
  subjectId String @db.Uuid
  examId    String @db.Uuid
  sortOrder Int    @default(0)

  subject Subject @relation(fields: [subjectId], references: [id])
  exam    Exam    @relation(fields: [examId], references: [id])

  @@id([subjectId, examId])
  @@index([examId])
}

model Topic {
  id        String @id @default(uuid()) @db.Uuid
  subjectId String @db.Uuid
  code      String
  label     String
  sortOrder Int    @default(0)

  subject    Subject     @relation(fields: [subjectId], references: [id])
  topicExams TopicExam[]
  questions  Question[]

  createdAt DateTime @default(now())

  @@unique([subjectId, code])
  @@index([subjectId])
}

model TopicExam {
  topicId   String @db.Uuid
  examId    String @db.Uuid
  sortOrder Int    @default(0)

  topic Topic @relation(fields: [topicId], references: [id])
  exam  Exam  @relation(fields: [examId], references: [id])

  @@id([topicId, examId])
  @@index([examId])
}

enum UserRole {
  student
  admin
}

enum AvatarTone {
  accent
  neutral
}

model User {
  id String @id @default(uuid()) @db.Uuid

  // identity
  email String? @unique
  name  String

  // auth
  password String?

  // profile
  avatarInitial String?    @db.Char(1)
  avatarTone    AvatarTone @default(neutral)
  school        String?
  grade         String?
  targetExam    String?

  // activity
  lastActiveAt    DateTime?
  emailVerifiedAt DateTime?

  // moderation & soft-delete
  role        UserRole  @default(student)
  isSuspended Boolean   @default(false)
  deletedAt   DateTime?

  // relations
  userExams    UserExam[]
  sessions     PracticeSession[]
  authSessions UserSession[]
  attempts     Attempt[]

  // timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([lastActiveAt])
  @@index([deletedAt])
}
